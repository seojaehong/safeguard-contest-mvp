# Law.go primary adapter
LAWGO_OC=
# Legacy alias used in earlier setup notes. Prefer LAWGO_OC for new deployments.
LAW_OC=
LAWGO_TARGET_ENV=production
# Use "force" only for offline local development. Leave empty in hosted environments.
LAWGO_MOCK_MODE=

# Korean Law MCP augmentation layer
# true면 Law.go 검색 결과를 korean-law-mcp 근거로 보강합니다.
KOREAN_LAW_MCP_ENABLED=false
# 미입력 시 LAWGO_OC를 재사용
KOREAN_LAW_MCP_LAW_OC=

# LLM answer generation
# Gemini is preferred when GEMINI_API_KEY is set.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_FALLBACK_MODELS=gemini-flash-latest,gemini-2.5-flash-lite
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Optional translation providers. SafeClaw works without these by using the built-in
# easy-Korean and multilingual safety phrase pack.
PAPAGO_CLIENT_ID=
PAPAGO_CLIENT_SECRET=
GOOGLE_TRANSLATION_API_KEY=

DATA_GO_KR_SERVICE_KEY=
KOSHA_SERVICE_KEY=
KOSHA_ACCIDENT_PROXY_URL=
KOSHA_ACCIDENT_PROXY_TOKEN=
WORK24_AUTH_KEY=
# Optional override. Default is:
# https://apis.data.go.kr/B551184/UlvryService/getUlvryPredcInfo
# SafeClaw adds Korea Institute of Energy Research real-time erythemal UV
# signals to the outdoor summer weather evidence bundle.
KIER_ERYTHEMAL_UV_ENDPOINT=
NEXT_PUBLIC_APP_NAME=SafeClaw

# Optional product workspace persistence
# Apply supabase/migrations/002_workspace_productization.sql before enabling writes.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Optional production smoke only. Use a short-lived Supabase user access token
# when scripts/submission_readiness_smoke.mjs must call protected storage APIs.
# The app UI uses the browser Supabase session, not this variable.
SAFEGUARD_AUTH_TOKEN=

# Optional workflow automation through your Oracle n8n instance
# Local or Oracle-internal runtime only. Do not set this in Vercel.
N8N_INTERNAL_BASE=http://127.0.0.1:5678
# Hosted runtimes such as Vercel must use a public HTTPS relay.
N8N_PUBLIC_BASE=
N8N_WEBHOOK_PATH=safeguard-workpack
N8N_WEBHOOK_TOKEN=
# Backward-compatible direct URL mode
N8N_WEBHOOK_URL=
N8N_WEBHOOK_SECRET=
# Real provider dispatch is disabled unless this is set to 1.
# Default route behavior returns a safe fixture response for email/SMS.
SAFEGUARD_RUN_LIVE_DISPATCH=0

# Optional Kakao AlimTalk channel through the n8n/Solapi provider.
# Set to 1 only after the Kakao channel is connected and the AlimTalk template is approved.
SAFEGUARD_KAKAO_ENABLED=0
# Keep these secrets on the Oracle n8n server whenever possible. They are listed
# here only to document the provider contract used by the n8n workflow.
SOLAPI_KAKAO_SENDER_KEY=
SOLAPI_KAKAO_TEMPLATE_ID=
SOLAPI_KAKAO_TEMPLATE_CODE=
SOLAPI_KAKAO_DISABLE_SMS=false
