# Law.go primary adapter
LAWGO_OC=
LAWGO_TARGET_ENV=demo
LAWGO_MOCK_MODE=true

# Korean Law MCP augmentation layer
# false면 기존 Law.go/mock 흐름만 사용
KOREAN_LAW_MCP_ENABLED=false
# 미입력 시 LAWGO_OC를 재사용
KOREAN_LAW_MCP_LAW_OC=

# LLM answer generation
# Gemini is preferred when GEMINI_API_KEY is set.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

DATA_GO_KR_SERVICE_KEY=
KOSHA_SERVICE_KEY=
WORK24_AUTH_KEY=
NEXT_PUBLIC_APP_NAME=산업안전 법령·판례 코파일럿
